[
  {
    "corsRuleName": "allowWebApp",
    "allowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000",
      "http://localhost:5174",
      "https://yourdomain.com"
    ],
    "allowedOperations": [
      "b2_download_file_by_name",
      "b2_download_file_by_id",
      "s3_get",
      "s3_head",
      "s3_put"
    ],
    "allowedHeaders": ["*"],
    "exposeHeaders": ["x-bz-content-sha1", "x-bz-file-id", "x-amz-request-id"],
    "maxAgeSeconds": 3600
  }
]
