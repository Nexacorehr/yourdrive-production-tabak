generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  firstName     String?  @map("first_name")
  email         String   @unique
  password      String
  emailVerified Boolean  @default(false) @map("emailVerified")
  loginAttempts Int      @default(0) @map("loginAttempts")
  lockUntil     DateTime? @map("lockUntil")
  createdAt     DateTime @default(now()) @map("createdAt")
  updatedAt     DateTime @updatedAt @map("updatedAt")
  
  sessions      Session[]
  userDevices   UserDevice[]
  userFiles     UserFile[]
  userSettings  UserSettings?

  totpSecret     String?  @map("totp_secret")
  totpEnabled    Boolean  @default(false) @map("totp_enabled")
  
  webauthnCredentials WebAuthnCredential[]
  socialAccounts      SocialAccount[]
  recoveryCodes       TotpRecoveryCode[]
  
  @@map("User")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("userId")
  refreshToken String   @unique
  deviceInfo   Json?
  expiresAt    DateTime @map("expiresAt")
  createdAt    DateTime @default(now()) @map("createdAt")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  
  @@index([userId])
  @@map("Session")
}

model UserDevice {
  id                   String   @id @default(uuid())
  userId               String   @map("user_id")
  deviceName           String   @map("device_name")
  deviceNickname       String?  @map("device_nickname")
  deviceType           String   @map("device_type")
  deviceColor          String   @default("#1a73e8") @map("device_color")
  browser              String?
  os                   String?
  ipAddress            String?  @map("ip_address")
  userAgent            String?  @map("user_agent")
  lastActive           DateTime @default(now()) @map("last_active")
  createdAt            DateTime @default(now()) @map("created_at")
  isCurrent            Boolean  @default(false) @map("is_current")
  isTrusted            Boolean  @default(false) @map("is_trusted")
  syncEnabled          Boolean  @default(true) @map("sync_enabled")
  storageLimit         BigInt?  @map("storage_limit")
  notificationsEnabled Boolean  @default(true) @map("notifications_enabled")
  lastLocation         String?  @map("last_location")
  isLocked             Boolean  @default(false) @map("is_locked")
  lockMessage          String?  @map("lock_message")
  lockedAt             DateTime? @map("locked_at")
  wipedAt              DateTime? @map("wiped_at")
  forceLogout          Boolean  @default(false) @map("force_logout")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([lastActive])
  @@map("user_devices")
}

model UserFile {
  id           Int      @id @default(autoincrement())
  userId       String   @map("user_id")
  userEmail    String   @map("user_email")
  originalName String   @map("original_name")
  s3Key        String   @map("s3_key")
  folderPath   String   @default("") @map("folder_path")
  size         BigInt
  fileHash     String?  @map("file_hash")
  mimeType     String   @map("mime_type")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([fileHash])
  @@index([folderPath])
  @@index([deletedAt])
  @@index([updatedAt])
  @@map("user_files")
}

model UserSettings {
  id         Int    @id @default(autoincrement())
  userId     String @unique @map("user_id")
  profile    Json   @default("{\"email\": \"\", \"firstName\": \"\", \"avatarUrl\": null}")
  security   Json   @default("{\"twoFactorEnabled\": false, \"clientSideEncryption\": false, \"offlineModeEnabled\": false}")
  appearance Json   @default("{\"theme\": \"system\", \"fileView\": \"grid\", \"thumbnailQuality\": \"medium\"}")
  language   Json   @default("{\"displayLanguage\": \"en\", \"dateFormat\": \"MM/DD/YYYY\", \"timeFormat\": \"12-hour\", \"timezone\": \"UTC\"}")
  storage    Json   @default("{\"autoSync\": true, \"fileVersioning\": true, \"maxVersionsToKeep\": 10}")
  sharing    Json   @default("{\"defaultLinkPermission\": \"view\", \"allowPublicSharing\": true, \"requirePasswordForLinks\": false, \"linkExpirationDays\": null, \"notifyOnShare\": true, \"allowDownload\": true}")
  preferences Json  @default("{\"emailNotifications\": true, \"desktopNotifications\": false, \"notifyOnUpload\": true, \"notifyOnShare\": true, \"notifyOnComment\": true, \"weeklyDigest\": false}")
  privacy    Json   @default("{\"showOnlineStatus\": true, \"allowActivityTracking\": true, \"shareUsageData\": false, \"indexFilesForSearch\": true}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("user_settings")
}

model WebAuthnCredential {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  credentialId String   @unique @map("credential_id")
  publicKey    String   @map("public_key")
  signCount    BigInt   @default(0) @map("sign_count")
  deviceName   String?  @map("device_name")
  createdAt    DateTime @default(now()) @map("created_at")
  lastUsed     DateTime? @map("last_used")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([credentialId])
  @@map("webauthn_credentials")
}

model SocialAccount {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  provider       String
  providerUserId String   @map("provider_user_id")
  email          String?
  accessToken    String?  @map("access_token")
  refreshToken   String?  @map("refresh_token")
  profileData    Json     @default("{}") @map("profile_data")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([provider])
  @@map("social_accounts")
}

model TotpRecoveryCode {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  codeHash  String    @map("code_hash")
  used      Boolean   @default(false)
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@map("totp_recovery_codes")
}