generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       String    @id @default(uuid())
  firstName                String?   @map("first_name")
  email                    String    @unique
  password                 String
  emailVerified            Boolean   @default(false) @map("emailVerified")
  emailVerificationToken   String?   @map("email_verification_token")
  emailVerificationExpires DateTime? @map("email_verification_expires")
  loginAttempts            Int       @default(0) @map("loginAttempts")
  lockUntil                DateTime? @map("lockUntil")
  createdAt                DateTime  @default(now()) @map("createdAt")
  updatedAt                DateTime  @updatedAt @map("updatedAt")
  totpSecret               String?   @map("totp_secret")
  totpEnabled              Boolean   @default(false) @map("totp_enabled")
  passwordResetToken       String?   @map("password_reset_token")
  passwordResetExpires     DateTime? @map("password_reset_expires")
  passwordResetCodeHash    String?   @map("password_reset_code_hash")

  sessions            Session[]
  userDevices         UserDevice[]
  userFiles           UserFile[]
  userSettings        UserSettings?
  shareActivities     ShareActivity[]
  fileShares          FileShare[]
  shareRecipients     ShareRecipient[]
  favoritedFiles      FavoritedFile[]
  recycleBinItems     RecycleBin[]
  webauthnCredentials WebAuthnCredential[]
  socialAccounts      SocialAccount[]
  recoveryCodes       TotpRecoveryCode[]

  @@index([emailVerificationToken])
  @@map("User")
}

model Session {
  id           String   @id @default(uuid())
  userId       String   @map("userId")
  refreshToken String   @unique
  deviceInfo   Json?
  expiresAt    DateTime @map("expiresAt")
  createdAt    DateTime @default(now()) @map("createdAt")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("Session")
}

model UserDevice {
  id                   String    @id @default(uuid())
  userId               String    @map("user_id")
  deviceName           String    @map("device_name")
  deviceNickname       String?   @map("device_nickname")
  deviceType           String    @map("device_type")
  deviceColor          String    @default("#1a73e8") @map("device_color")
  browser              String?
  os                   String?
  ipAddress            String?   @map("ip_address")
  userAgent            String?   @map("user_agent")
  lastActive           DateTime  @default(now()) @map("last_active")
  createdAt            DateTime  @default(now()) @map("created_at")
  isCurrent            Boolean   @default(false) @map("is_current")
  isTrusted            Boolean   @default(false) @map("is_trusted")
  syncEnabled          Boolean   @default(true) @map("sync_enabled")
  storageLimit         BigInt?   @map("storage_limit")
  notificationsEnabled Boolean   @default(true) @map("notifications_enabled")
  lastLocation         String?   @map("last_location")
  isLocked             Boolean   @default(false) @map("is_locked")
  lockMessage          String?   @map("lock_message")
  lockedAt             DateTime? @map("locked_at")
  wipedAt              DateTime? @map("wiped_at")
  forceLogout          Boolean   @default(false) @map("force_logout")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastActive])
  @@map("user_devices")
}

model UserFile {
  id                Int          @id @default(autoincrement())
  userId            String       @map("user_id")
  userEmail         String       @map("user_email")
  originalName      String       @map("original_name")
  s3Key             String       @map("s3_key")
  folderPath        String       @default("") @map("folder_path")
  size              BigInt
  fileHash          String?      @map("file_hash")
  mimeType          String       @map("mime_type")
  isFolder          Boolean      @default(false) @map("is_folder")
  isLocked          Boolean      @default(false) @map("is_locked")
  isSystemReadme    Boolean      @default(false) @map("is_system_readme")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  deletedAt         DateTime?    @map("deleted_at")
  recycleBinEntries RecycleBin[]

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  shares    FileShare[]
  favorites FavoritedFile[]

  @@unique([userId, folderPath, originalName])
  @@index([userId])
  @@index([folderPath])
  @@index([deletedAt])
  @@index([updatedAt])
  @@index([isLocked])
  @@index([isFolder])
  @@map("user_files")
}

model FavoritedFile {
  id          Int      @id @default(autoincrement())
  userId      String   @map("user_id")
  fileId      Int      @map("file_id")
  favoritedAt DateTime @default(now()) @map("favorited_at")

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  file UserFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([userId, fileId])
  @@index([userId])
  @@index([fileId])
  @@map("favorited_files")
}

model UserSettings {
  id          Int      @id @default(autoincrement())
  userId      String   @unique @map("user_id")
  profile     Json     @default("{\"email\": \"\", \"avatarUrl\": null, \"firstName\": \"\"}")
  security    Json     @default("{\"twoFactorEnabled\": false, \"offlineModeEnabled\": false, \"clientSideEncryption\": false}")
  appearance  Json     @default("{\"theme\": \"system\", \"fileView\": \"grid\", \"thumbnailQuality\": \"medium\"}")
  language    Json     @default("{\"timezone\": \"UTC\", \"dateFormat\": \"MM/DD/YYYY\", \"timeFormat\": \"12-hour\", \"displayLanguage\": \"en\"}")
  storage     Json     @default("{\"autoSync\": true, \"fileVersioning\": true, \"maxVersionsToKeep\": 10}")
  sharing     Json     @default("{\"allowDownload\": true, \"notifyOnShare\": true, \"allowPublicSharing\": true, \"linkExpirationDays\": null, \"defaultLinkPermission\": \"view\", \"requirePasswordForLinks\": false}")
  preferences Json     @default("{\"weeklyDigest\": false, \"notifyOnShare\": true, \"notifyOnUpload\": true, \"notifyOnComment\": true, \"emailNotifications\": true, \"desktopNotifications\": false}")
  privacy     Json     @default("{\"shareUsageData\": false, \"showOnlineStatus\": true, \"indexFilesForSearch\": true, \"allowActivityTracking\": true}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model WebAuthnCredential {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  credentialId String    @unique @map("credential_id")
  publicKey    String    @map("public_key")
  signCount    BigInt    @default(0) @map("sign_count")
  deviceName   String?   @map("device_name")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastUsed     DateTime? @map("last_used")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("webauthn_credentials")
}

model SocialAccount {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  provider       String
  providerUserId String   @map("provider_user_id")
  email          String?
  accessToken    String?  @map("access_token")
  refreshToken   String?  @map("refresh_token")
  profileData    Json     @map("profile_data")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("social_accounts")
}

model TotpRecoveryCode {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  codeHash  String    @map("code_hash")
  used      Boolean   @default(false)
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("totp_recovery_codes")
}

model FileShare {
  id              String           @id @default(uuid())
  fileId          Int              @map("file_id")
  ownerId         String          @map("owner_id")
  shareToken      String          @unique @map("share_token")
  shortId         String?         @unique @map("short_id")
  shareType       String          @map("share_type")
  permission      String
  password        String?
  expiresAt       DateTime?       @map("expires_at")
  maxDownloads    Int?            @map("max_downloads")
  downloadCount   Int             @default(0) @map("download_count")
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  file            UserFile        @relation(fields: [fileId], references: [id], onDelete: Cascade)
  owner           User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  activities      ShareActivity[]
  comments        ShareComment[]
  shareRecipients ShareRecipient[]

  @@map("file_shares")
}

model ShareRecipient {
  id               String   @id @default(uuid())
  shareId          String   @map("share_id")
  recipientUserId  String   @map("recipient_user_id")
  createdAt        DateTime @default(now()) @map("created_at")
  share            FileShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  recipient        User      @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)

  @@unique([shareId, recipientUserId])
  @@index([recipientUserId])
  @@map("share_recipients")
}

model ShareComment {
  id        String    @id @default(uuid())
  shareId   String    @map("share_id")
  userName  String    @map("user_name")
  text      String
  createdAt DateTime  @default(now()) @map("created_at")
  share     FileShare @relation(fields: [shareId], references: [id], onDelete: Cascade)

  @@map("share_comments")
}

model ShareActivity {
  id        Int       @id @default(autoincrement())
  shareId   String    @map("share_id")
  userId    String?   @map("user_id")
  action    String
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  share     FileShare @relation(fields: [shareId], references: [id], onDelete: Cascade)
  user      User?     @relation(fields: [userId], references: [id])

  @@map("share_activity")
}

model RecycleBin {
  id               Int      @id @default(autoincrement())
  userId           String   @map("user_id")
  fileId           Int      @map("file_id")
  originalName     String   @map("original_name")
  s3Key            String   @map("s3_key")
  userEmail        String   @map("user_email")
  mimeType         String   @map("mime_type")
  size             BigInt
  folderPath       String   @default("") @map("folder_path")
  isSystemReadme   Boolean  @default(false) @map("is_system_readme")
  deletedAt        DateTime @default(now()) @map("deleted_at")
  createdAt        DateTime @default(now()) @map("created_at")

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  UserFile   UserFile? @relation(fields: [userFileId], references: [id])
  userFileId Int?

  @@unique([userId, fileId])
  @@index([userId])
  @@index([fileId])
  @@index([deletedAt])
  @@map("recycle_bin")
}
