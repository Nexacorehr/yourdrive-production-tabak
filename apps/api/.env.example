# ─── Database (required) ─────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/yourdrive?schema=public"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ─── Auth (required in production) ───────────────────────────────────────────
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

# ─── URLs (required in production) ───────────────────────────────────────────
# Netlify frontend origin (CORS + email links)
FRONTEND_URL=http://localhost:5173
# Public API base (OAuth callbacks, share links)
BACKEND_URL=http://localhost:3000

# ─── Storage — Backblaze B2 / S3 (required for uploads) ─────────────────────
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET_NAME=
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
B2_REGION=eu-central-003
B2_PUBLIC_URL=

# ─── Email (optional — verification / password reset) ────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdrive.app
SUPPORT_EMAIL=support@yourdrive.app

# ─── OAuth (optional) ────────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ─── Vert conversion (optional) ──────────────────────────────────────────────
# VERT_URL=http://localhost:3003
