# Database
# PostgreSQL (production). For SQLite dev use file:./dev.db in a separate env.
DATABASE_URL="postgresql://user:password@localhost:5432/nexacore"

# Storage (Backblaze B2 or S3-compatible)
# API uses B2_*; AWS_* names are also supported as aliases in some modules.
B2_ENDPOINT="https://s3.us-west-002.backblazeb2.com"
B2_REGION="us-west-002"
B2_BUCKET_NAME="nexacore-files"
B2_KEY_ID="your-key-id"
B2_APPLICATION_KEY="your-secret-key"
# Avatar URLs (only if using B2 for avatars). If B2_KEY_ID/B2_APPLICATION_KEY/B2_BUCKET_NAME
# are not set, avatars are stored as base64 in the database (no B2 or public URL needed).
# B2_PUBLIC_URL="https://f004.backblazeb2.com/file/nexacore-files"

# JWT (use different secrets in production)
JWT_ACCESS_SECRET="generate-strong-random-secret"
JWT_REFRESH_SECRET="generate-strong-random-secret"
# Optional: for 2FA temp tokens (defaults to a fallback if unset)
JWT_TEMP_SECRET="generate-another-secret"

# Application
NODE_ENV="production"
PORT="3001"
HOST="0.0.0.0"
# Public browser URL of the web app (share links, verification emails, etc.).
# Use your stable hostname (e.g. https://drive.example.com). Do not put a Cloudflare quick-tunnel
# (*.trycloudflare.com) here — tunnels change; FRONTEND_URL is always preferred when set.
FRONTEND_URL="https://your-domain.com"
BACKEND_URL="https://api.your-domain.com"
VERT_URL="https://your-domain.com"

# CORS: FRONTEND_URL is used automatically. For Cloudflare quick tunnels, add:
# CORS_ORIGINS=https://your-subdomain.trycloudflare.com
# (or leave unset; *.trycloudflare.com is allowed by default)

# Email (verification and notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="NEXA Core <noreply@your-domain.com>"

# Optional: OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""

# WebAuthn / Passkeys
RP_NAME="NEXA Core"
RP_ID="localhost"
RP_ORIGIN="http://localhost:5173"
BACKEND_DOMAIN="localhost"

# Bcrypt
BCRYPT_ROUNDS=12
